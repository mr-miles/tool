{
  "$schema": "https://raw.githubusercontent.com/mr-miles/tool/main/schema/dotnet-diff-coverage.schema.json",
  "testFilePatterns": [
    "tests/**",
    "test/**",
    "**/*.Tests.cs",
    "**/*.Test.cs",
    "**/*.Spec.cs",
    "**/*Tests.cs",
    "**/*Test.cs",
    "**/*Specs.cs",
    "**/*Fixture.cs",
    "**/*Fixtures.cs"
  ],
  "excludePatterns": [
    "**/*.yml",
    "**/*.yaml",
    "**/*.json",
    "**/*.md",
    "**/*.xml",
    "**/*.txt",
    "**/*.csproj",
    "**/*.sln",
    "**/*.props",
    "**/*.targets",
    "**/*.config"
  ],
  "threshold": 0
}
